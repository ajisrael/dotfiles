#!/usr/bin/env bash

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
default_config="$script_dir/.default-tmux-sessionizer-config"
target="$PWD/.tmux-sessionizer-config"

if [[ ! -f "$default_config" ]]; then
	echo "Default config not found: $default_config" >&2
	exit 1
fi

if [[ ! -f "$target" ]]; then
	cp "$default_config" "$target"
fi

nvim "$target"
